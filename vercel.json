{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/phase2_sprint0.py": {
      "includeFiles": "{source.zip,artifacts/sprint0_parts/**,app/phase2_*.py}",
      "maxDuration": 60
    }
  },
  "rewrites": [
